# ──────────────────────────────────────────────────────
# FHIR Questionnaire Generation Pipeline - Environment
# ──────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# ─── Required ────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Optional overrides ─────────────────────────────
# Host port to expose the policy-preprocessor service
# EXPOSED_PORT=6080

# Anthropic gateway URLs (defaults to official API)
# ANTHROPIC_GENERATOR_AGENT_AI_GATEWAY_URL=https://api.anthropic.com/v1
# ANTHROPIC_REVIEWER_AGENT_AI_GATEWAY_URL=https://api.anthropic.com/v1

# Agent orchestration conversation limit
# AGENT_CONV_LIMIT=5

# FHIR server URL (defaults to localhost)
# FHIR_SERVER_URL=http://localhost:9090/fhir/r4
